# ============================================================
# 服务端口配置
# ============================================================
PORT=3001
VITE_WS_URL=ws://localhost:3001
VITE_API_URL=http://localhost:3001

# ============================================================
# 数据库配置
# ============================================================
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=power_grid
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ============================================================
# 业务参数配置
# ============================================================
STATIC_CAPACITY=1000
MAX_ALLOWED_TEMP=70
LINE_LENGTH_KM=200
SENSOR_REPORT_INTERVAL=10000

# ============================================================
# 模拟器配置（可选）
# ============================================================
SIMULATOR_WS_URL=ws://localhost:3001/ws
SIMULATOR_INTERVAL=10000

# ============================================================
# 时区配置
# ============================================================
TZ=Asia/Shanghai

# ============================================================
# Docker Compose 配置
# ============================================================
# 数据卷路径（可选，用于持久化到主机特定目录）
# TIMESCALEDB_DATA_PATH=./data/timescaledb
